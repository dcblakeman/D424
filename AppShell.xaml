<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="C_971.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:C_971"
    xmlns:views="clr-namespace:C_971.Views"
    Title="C_971"
    FlyoutBehavior="Disabled">
    
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <ShellContent
            ContentTemplate="{DataTemplate views:AcademicTermListView}"
            Route="AcademicTermListView"/>
    <!-- Additional routes for navigation -->
    <ShellContent
        ContentTemplate="{DataTemplate views:CourseListView}"
        Route="CourseListView"/>
    <ShellContent
        ContentTemplate="{DataTemplate views:CourseDetailsView}"
        Route="CourseDetailsView"/>
    <ShellContent
        ContentTemplate="{DataTemplate views:AddNoteView}"
        Route="AddNoteView"/>
    <ShellContent
        ContentTemplate="{DataTemplate views:ViewNotesView}"
        Route="ViewNotesView"/>
</Shell>