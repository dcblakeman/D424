<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C_971.Views.AssessmentSelectionView"
             xmlns:vm="clr-namespace:C_971.ViewModels"
             xmlns:models="clr-namespace:C_971.Models"
             x:DataType="vm:AssessmentSelectionViewModel"
             Title="{Binding ViewName}">

    <Shell.TitleView>
        <Label Text="{Binding ViewName}" 
            FontSize="24" 
            FontAttributes="Bold"
            TextColor="Black"
            VerticalOptions="Center"
            HorizontalOptions="Center" />
    </Shell.TitleView>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto" Margin="23" RowSpacing="10">
        <!-- Main buttons frame -->
        <Frame Grid.Row="0"
           BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
           HasShadow="True" 
           CornerRadius="10" 
           Padding="20"
           Margin="0,120,0,0">
            <StackLayout>
                <Button Text="Performance"
                    Command="{Binding NavigateToPerformanceAssessmentViewCommand}"
                    BackgroundColor="#4A90E2" 
                    FontAttributes="Bold"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8"
                    Padding="17"
                    Margin="5"
                    HorizontalOptions="Fill" />
                <Button Text="Objective"
                    Command="{Binding NavigateToObjectiveAssessmentViewCommand}"
                    BackgroundColor="#5CB85C" 
                    FontAttributes="Bold"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8"
                    Padding="17"
                    Margin="5"
                    HorizontalOptions="Fill" />
                <Button Text="Reports"
                    Command="{Binding NavigateToReportViewCommand}"
                    BackgroundColor="Purple" 
                    FontAttributes="Bold"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8"
                    Padding="17"
                    Margin="5"
                    HorizontalOptions="Fill" />
            </StackLayout>
        </Frame>

        <!-- Empty space in the middle -->

        <!-- Back button frame at bottom -->
        <Frame Grid.Row="2"
           BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
           HasShadow="True" 
           CornerRadius="10" 
           Padding="15"
           Margin="0,0,0,20"
           VerticalOptions="End">
            <Button Text="Back"
                BackgroundColor="#6C757D" 
                FontAttributes="Bold"
                TextColor="White"
                HeightRequest="50"
                CornerRadius="8"
                Padding="17"
                HorizontalOptions="Fill"
                Command="{Binding GoBackCommand}" />
        </Frame>
    </Grid>

</ContentPage>
