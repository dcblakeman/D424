<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C_971.Views.ReportView"
             xmlns:vm="clr-namespace:C_971.ViewModels"
             xmlns:models="clr-namespace:C_971.Models"
             x:DataType="vm:ReportViewModel">

    <ScrollView>
        <!-- Reports Section -->
        <VerticalStackLayout Spacing="20" Padding="20">
            
            <Label Text="Generate Reports" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,20"/>

            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20">
                
                <VerticalStackLayout Spacing="10">
                    <Label Text="Generate Reports" 
                           FontSize="18" 
                           FontAttributes="Bold"/>

                    <Button Text="Generate Courses Report"
                            Command="{Binding GenerateCourseReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                    <Button Text="Generate Assessments Report"
                            Command="{Binding GenerateAssessmentReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                    <Button Text="Generate Courses with Assessments Report"
                            Command="{Binding GenerateCoursesWithAssessmentsReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20">
                 
                <VerticalStackLayout Spacing="15">
                    <Label Text="Report Tools" 
                           FontSize="18" 
                           FontAttributes="Bold"/>
                    <Button Text="Open Report" 
                            Command="{Binding OpenReportCommand}"
                            BackgroundColor="{StaticResource SecondaryDarkText}" />
                </VerticalStackLayout>
            </Frame>

            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20">

                <VerticalStackLayout Spacing="10">
                    <Button Text="Back"
                            Command="{Binding GoBackCommand}"
                            BackgroundColor="{AppThemeBinding Light=DarkRed, Dark=Red}"
                            TextColor="White"
                            FontSize="14"
                            HeightRequest="40"
                            CornerRadius="6"/>
                    
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
