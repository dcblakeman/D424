<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C_971.Views.ReportView"
             xmlns:vm="clr-namespace:C_971.ViewModels"
             xmlns:models="clr-namespace:C_971.Models"
             x:DataType="vm:ReportViewModel">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">

            <!-- Header -->
            <Label Text="Generate Reports" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" 
                   Margin="0,0,0,20"/>



            <!-- Report Folder Configuration Settings Frame -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20">
                
                <VerticalStackLayout Spacing="15">
                    <!-- View Reports Button -->
                        <Button Text="Open Report" 
                            Command="{Binding OpenReportCommand}"
                            BackgroundColor="{StaticResource SecondaryDarkText}" />

                    <!-- Share Reports Button -->
                    <Button Text="Share Reports" 
                            Command="{Binding ShareReportsCommand}"
                            BackgroundColor="{StaticResource MidnightBlue}" />

                    <!-- Change Reports Folder -->
                    <Button Text="Show Current Reports Folder" 
                            Command="{Binding ShowCurrentReportsFolderCommand}"
                            BackgroundColor="{StaticResource Tertiary}" />

                    <!-- Change Reports Folder -->
                    <Button Text="Change Reports Folder" 
                            Command="{Binding ChangeReportsFolderCommand}"
                            BackgroundColor="{StaticResource PrimaryDark}" />

                    <!-- Reset Reports Folder -->
                    <Button Text="Reset Reports Folder" 
                            Command="{Binding ResetReportsFolderCommand}"
                            BackgroundColor="{StaticResource Gray300}" />
                </VerticalStackLayout>
            </Frame>
            <!-- End Report Configuration Settings Frame -->
            
            
            
            
            <!-- Reports Buttons Section Frame -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Generate Reports" 
                           FontSize="18" 
                           FontAttributes="Bold"/>
                    
                    <!-- Buttons Section -->
                    <Button Text="Generate Courses Report"
                            Command="{Binding GenerateCourseReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                    <Button Text="Generate Assessments Report"
                            Command="{Binding GenerateAssessmentReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                    <Button Text="Generate Performance Report"
                            Command="{Binding GenerateCoursesWithAssessmentsReportCommand}"
                            BackgroundColor="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"
                            TextColor="White"
                            HeightRequest="50"
                            CornerRadius="8"/>
                    
                </VerticalStackLayout>
            </Frame>
            <!-- End Reports Section / Frame -->
            
            
            
            <!-- Status and Progress Frame / Section -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20"
                   IsVisible="{Binding IsGeneratingReport}">

                <VerticalStackLayout Spacing="10">
                    <ActivityIndicator IsRunning="{Binding IsGeneratingReport}" 
                                       Color="{AppThemeBinding Light=#007ACC, Dark=#0078D4}"/>
                    <Label Text="{Binding StatusMessage}" 
                           HorizontalOptions="Center"
                           FontSize="14"/>
                </VerticalStackLayout>
            </Frame>
            <!-- End of Status and Progress Frame/Section -->

            
            
           

            <!-- Not sure what this is?? -->
            <!-- Recent Reports -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20"
                   IsVisible="{Binding HasRecentReports}">

                <VerticalStackLayout Spacing="10">
                    <Label Text="Recent Reports" 
                           FontSize="18" 
                           FontAttributes="Bold"/>

                    <CollectionView ItemsSource="{Binding RecentReports}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="5" x:DataType="{x:Type x:String}">
                                    <Label Text="{Binding .}" 
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#6C757D, Dark=#ADB5BD}"/>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            
            

            <!-- Save and Go Back Buttons Frame -->
            <!-- Go Back Button -->
            <Frame BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#2D3748}" 
                   HasShadow="True" 
                   CornerRadius="10" 
                   Padding="20"
                   IsVisible="{Binding HasRecentReports}">

                <VerticalStackLayout Spacing="10">
                    
                    <!-- Save Button -->
                    <Button Text="Save Report To Custom Folder"
                            Command="{Binding SaveReportToCustomFolderCommand}"
                            BackgroundColor="DarkGreen"
                            TextColor="White"/>
                    
                    <!-- Back Button -->
                    <Button Text="Back"
                            Command="{Binding GoBackCommand}"
                            BackgroundColor="{AppThemeBinding Light=DarkRed, Dark=Red}"
                            TextColor="White"
                            FontSize="14"
                            HeightRequest="40"
                            CornerRadius="6"/>
                    
                </VerticalStackLayout>
            </Frame>
            <!-- End Save and Go Back Buttons Frame -->


        </VerticalStackLayout>
    </ScrollView>

</ContentPage>