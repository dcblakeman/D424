<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C_971.Views.CourseInstructorView"
             xmlns:vm="clr-namespace:C_971.ViewModels"
             xmlns:model="clr-namespace:C_971.Models"
             x:DataType="vm:CourseInstructorViewModel">

    <Shell.TitleView>
        <Label Text="{Binding Name}" 
               FontSize="24" 
               FontAttributes="Bold"
               TextColor="Black"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Search Bar Border -->
        <Border Grid.Row="0"
                Stroke="#2196F3"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="10,0,10,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>

            <!-- Search Bar -->
            <SearchBar x:Name="ContentSearchBar"
                        Placeholder="Search by instructor name..."
                        SearchCommand="{Binding SearchCommand}"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        BackgroundColor="Transparent"
                        TextColor="Black"
                        PlaceholderColor="Gray"
                        FontSize="16"
                        Margin="5"/>
        </Border>
        <!-- End Search Bar Border -->

        <!-- Buttons Section -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" Padding="10,0,10,5">
            <!-- Add Course Button -->
            <Button Grid.Column="0"
                    Text="Add Instructor"
                    Command="{Binding AddCourseInstructorCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingInstructor}"
                    Padding="17"/>

            <!-- Remove Instructor Button -->
            <Button Grid.Column="1"
                    Text="Remove Instructor"
                    Command="{Binding RemoveInstructorCommand}"
                    BackgroundColor="#F44336"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingCourseInstructor}"/>

            <!-- Back Button -->
            <Button Grid.Column="2"
                    Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Grey"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingCourseInstructor}"/>
        </Grid>
        <!-- End Buttons Section -->

        <!-- Remove Mode Instructions -->
        <!-- Remove Mode Border -->
        <Border Grid.Row="2"
                BackgroundColor="LightCoral"
                Stroke="Red"
                StrokeThickness="1"
                Padding="10"
                Margin="15,0,15,10"
                IsVisible="{Binding IsRemovingCourseInstructor}">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5"/>
            </Border.StrokeShape>

            <!-- Remove Mode View -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                           Text="Select a course instructor to remove"
                           FontAttributes="Bold"
                           TextColor="DarkRed"
                           VerticalOptions="Center"/>

                <Button Grid.Column="1"
                        Text="Cancel"
                        Command="{Binding CancelRemoveCourseInstructorCommand}"
                        BackgroundColor="Gray"
                        TextColor="White"/>
            </Grid>
        </Border>
        <!-- End Remove Mode Border -->

        <!-- Add New Course Section -->
        <Border Grid.Row="1" 
                Stroke="DarkBlue" 
                StrokeThickness="2" 
                Padding="10" 
                BackgroundColor="AliceBlue" 
                Margin="10"
                IsVisible="{Binding IsAddingCourseInstructor}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5"/>
            </Border.StrokeShape>

            <!-- New Course Instructor View Row Defitions-->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="5" IsVisible="{Binding IsAddingCourseInstructor}">

                <!-- Header -->
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                       Text="Add New Course Instructor" 
                       FontAttributes="Bold" 
                       FontSize="16" 
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,10"/>

                <!-- New Course Instructor Entries -->
                <!-- ID -->
                <Label Grid.Row="0" Grid.Column="0" Text="ID:" FontAttributes="Bold" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>
                <Label Grid.Row="0" Grid.Column="1" Text="{Binding Instructor.Id}" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>

                <!-- Name -->
                <Label Grid.Row="1" Grid.Column="0" Text="Name:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Grid.Row="1" Grid.Column="1" Text="{Binding Instructor.Name}" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>
                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding Instructor.Name, Mode=TwoWay}" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>

                <!-- Email -->
                <Label Grid.Row="2" Grid.Column="0" Text="Email:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Grid.Row="2" Grid.Column="1" Text="{Binding Instructor.Email}" VerticalOptions="Center" IsVisible="{Binding IsNotEditing}"/>
                <Entry Grid.Row="2" Grid.Column="1" Text="{Binding Instructor.Email, Mode=TwoWay}" Keyboard="Email" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>

                <!-- Phone Number -->
                <Label Grid.Row="3" Grid.Column="0" Text="Phone:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Label Grid.Row="3" Grid.Column="1" Text="{Binding Instructor.Phone}" VerticalOptions="Center" IsVisible="{Binding IsNotEditing}"/>
                <Entry Grid.Row="3" Grid.Column="1" Text="{Binding Instructor.Phone, Mode=TwoWay}" Keyboard="Telephone" VerticalOptions="Center" IsVisible="{Binding IsAddingCourseInstructor}"/>
                <!-- End New Course Instructor Entries -->

                <!-- Save/Cancel Button Grid Definitions -->
                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">

                    <!-- Save Course Instructor Button -->
                    <Button Text="Save" 
                            Grid.Column="0"
                            Command="{Binding SaveNewCourseInstructorCommand}"
                            BackgroundColor="#2196F3"
                            TextColor="White"/>

                    <!-- Cancel Course Instructor Button -->
                    <Button Text="Cancel" 
                            Grid.Column="1"
                            Command="{Binding CancelAddCourseInstructorCommand}"
                            BackgroundColor="Gray"
                            TextColor="White"/>
                </Grid>
                <!-- End Save/Cancel Button Grid Section -->
            </Grid>
        </Border>
        <!-- End Add New Course Instructor Section -->

        <!-- Instructor List Section -->
        <RefreshView Grid.Row="3"
                         Command="{Binding LoadCourseInstructorsCommand}"  
                         IsRefreshing="{Binding IsRefreshing}">

            <!-- Calls Instructors List -->
            <CollectionView ItemsSource="{Binding Instructors}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:CourseInstructor">

                        <Grid Padding="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border StrokeThickness="1"   
                            Stroke="LightGray"   
                            Padding="10">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnInstructorTapped"/>
                                </Border.GestureRecognizers>

                                <!-- Instructor Entries -->
                                <VerticalStackLayout Spacing="5">
                                    
                                    <!-- ID -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="ID:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Id}"/>
                                    </HorizontalStackLayout>

                                    <!-- Name -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Name:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Name}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <HorizontalStackLayout Grid.Column="0" Spacing="10">
                                            <Label Text="Instructor Name:" FontAttributes="Bold"/>
                                            <Label>
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Name}" />
                                                        <Span Text=" " />
                                                        <Span Text="(" />
                                                        <Span Text="{Binding Email}" />
                                                        <Span Text=")" />
                                                        <Span Text=")" />
                                                        <Span Text="{Binding Phone}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>


                                        
                                        
                                        
                                        
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Empty Course Instructor Section -->
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="No courses available"   
                               HorizontalOptions="Center"  
                               FontSize="18"  
                               TextColor="Gray"/>
                    </StackLayout>
                </CollectionView.EmptyView>
                <!-- End Empty Course Instructor Section -->
                
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>