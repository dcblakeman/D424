<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="C_971.Views.CourseInstructorView"
             xmlns:vm="clr-namespace:C_971.ViewModels"
             xmlns:model="clr-namespace:C_971.Models"
             x:DataType="vm:CourseInstructorViewModel">

    <Shell.TitleView>
        <Label Text="{Binding ViewName}" 
               FontSize="24" 
               FontAttributes="Bold"
               TextColor="Black"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Search Bar Border -->
        <Border Grid.Row="0"
                Stroke="#2196F3"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="10,0,10,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>

            <!-- Search Bar -->
            <SearchBar x:Name="ContentSearchBar"
                        Placeholder="Search by instructor name..."
                        SearchCommand="{Binding SearchCommand}"
                        Text="{Binding SearchText, Mode=TwoWay}"
                        BackgroundColor="Transparent"
                        TextColor="Black"
                        PlaceholderColor="Gray"
                        FontSize="16"
                        Margin="5"/>
        </Border>
        <!-- End Search Bar Border -->

        <!-- Buttons Section -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8" Padding="10,0,10,5">
            <!-- Add Instructor Button -->
            <Button Grid.Column="0"
            Text="Add Instructor"
            Command="{Binding StartAddingInstructorCommand}"
            BackgroundColor="#2196F3"
            TextColor="White"
            IsVisible="{Binding IsNotAddingInstructor}"
            Padding="17"/>

            <!-- Remove Instructor Button -->
            <Button Grid.Column="1"
            Text="Remove Instructor"
            Command="{Binding RemoveInstructorCommand}"
            BackgroundColor="#F44336"
            TextColor="White"
            IsVisible="{Binding IsNotAddingInstructor}"/>

            <!-- Back Button -->
            <Button Grid.Column="2"
            Text="Back"
            Command="{Binding GoBackCommand}"
            BackgroundColor="Grey"
            TextColor="White"
            IsVisible="{Binding IsNotAddingInstructor}"/>
        </Grid>

        <!-- Remove Mode Instructions -->
        <Border Grid.Row="2"
        BackgroundColor="LightCoral"
        Stroke="Red"
        StrokeThickness="1"
        Padding="10"
        Margin="15,0,15,10"
        IsVisible="{Binding IsRemovingInstructor}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5"/>
            </Border.StrokeShape>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
               Text="Select a course instructor to remove"
               FontAttributes="Bold"
               TextColor="DarkRed"
               VerticalOptions="Center"/>

                <Button Grid.Column="1"
                Text="Cancel"
                Command="{Binding CancelRemoveInstructorCommand}"
                BackgroundColor="Gray"
                TextColor="White"/>
            </Grid>
        </Border>

        <!-- Add New Instructor Section - Fixed Row and Bindings -->
        <Border Grid.Row="2" 
        Stroke="DarkBlue" 
        StrokeThickness="2" 
        Padding="10" 
        BackgroundColor="AliceBlue" 
        Margin="10"
        IsVisible="{Binding IsAddingInstructor}">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="5"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="10">
                <Label Text="Add New Instructor" 
               FontAttributes="Bold" 
               FontSize="16" 
               HorizontalTextAlignment="Center"/>

                <!-- Name Entry -->
                <VerticalStackLayout Spacing="3">
                    <Label Text="Name:" FontAttributes="Bold"/>
                    <Entry Text="{Binding NewInstructorName, Mode=TwoWay}" 
                   Placeholder="Enter instructor name"/>
                </VerticalStackLayout>

                <!-- Email Entry -->
                <VerticalStackLayout Spacing="3">
                    <Label Text="Email:" FontAttributes="Bold"/>
                    <Entry Text="{Binding NewInstructorEmail, Mode=TwoWay}" 
                   Placeholder="Enter email address"
                   Keyboard="Email"/>
                </VerticalStackLayout>

                <!-- Phone Entry -->
                <VerticalStackLayout Spacing="3">
                    <Label Text="Phone:" FontAttributes="Bold"/>
                    <Entry Text="{Binding NewInstructorPhone, Mode=TwoWay}" 
                   Placeholder="Enter phone number"
                   Keyboard="Telephone"/>
                </VerticalStackLayout>

                <!-- Save/Cancel Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">
                    <Button Text="Save Instructor" 
                    Command="{Binding AddCourseInstructorCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"/>

                    <Button Grid.Column="1"
                    Text="Cancel" 
                    Command="{Binding CancelAddInstructorCommand}"
                    BackgroundColor="Gray"
                    TextColor="White"/>
                </Grid>
            </VerticalStackLayout>
        </Border>
        <!-- End Add New Course Instructor Section -->

        <!-- Instructor List Section -->
        <RefreshView Grid.Row="3"
                     IsRefreshing="{Binding IsRefreshing}">

            <!-- Calls Instructors List -->
            <CollectionView ItemsSource="{Binding Instructors}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:CourseInstructor">

                        <Grid Padding="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border StrokeThickness="1"   
                            Stroke="LightGray"   
                            Padding="10">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnInstructorTapped"/>
                                </Border.GestureRecognizers>

                                <!-- Instructor Entries -->
                                <VerticalStackLayout Spacing="5">
                                    
                                    <!-- ID -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="ID:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Id}"/>
                                    </HorizontalStackLayout>

                                    <!-- Name -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Name:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Name}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>

                                    <!-- Email -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Email:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Email}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>

                                    <!-- Phone -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Phone:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Phone}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Empty Course Instructor Section -->
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="No instructors available"   
                               HorizontalOptions="Center"  
                               FontSize="18"  
                               TextColor="Gray"/>
                    </StackLayout>
                </CollectionView.EmptyView>
                <!-- End Empty Course Instructor Section -->
                
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>