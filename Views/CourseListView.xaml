<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"  
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"  
             x:Class="C_971.Views.CourseListView"  
             xmlns:model="clr-namespace:C_971.Models"  
             xmlns:viewmodel="clr-namespace:C_971.ViewModels"  
             x:DataType="viewmodel:CourseListViewModel">

    <Shell.TitleView>
        <Label Text="{Binding ViewName}" 
               FontSize="24" 
               FontAttributes="Bold"
               TextColor="Black"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>
    
    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="False" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Search Bar Border -->
        <Border Grid.Row="0"
                Stroke="#2196F3"
                StrokeThickness="1"
                BackgroundColor="White"
                Margin="10,0,10,10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>

            <!-- Search Bar Section -->
            <SearchBar x:Name="ContentSearchBar"
                       Placeholder="Search by course name..."
                       SearchCommand="{Binding SearchCommand}"
                       Text="{Binding SearchText, Mode=TwoWay}"
                       BackgroundColor="Transparent"
                       TextColor="Black"
                       PlaceholderColor="Gray"
                       FontSize="16"
                       Margin="5"/>
        </Border>
        <!-- End Search Bar Border -->

        <!-- Buttons Section -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,*" ColumnSpacing="8" Padding="10,0,10,5">
            <!-- Add Course Button -->
            <Button Grid.Column="0"
                    Text="Add Course"
                    Command="{Binding AddCourseCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingCourse}"
                    Padding="17"/>

            <!-- Remove Course Button -->
            <Button Grid.Column="1"
                    Text="Remove Course"
                    Command="{Binding RemoveCourseCommand}"
                    BackgroundColor="#F44336"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingCourse}"/>

            <!-- Back Button -->
            <Button Grid.Column="2"
                    Text="Back"
                    Command="{Binding GoBackCommand}"
                    BackgroundColor="Grey"
                    TextColor="White"
                    IsVisible="{Binding IsNotAddingCourse}"/>
        </Grid>
        <!-- End Buttons Section -->

        <!-- Remove Mode Instructions -->
        <!-- Remove Mode Border -->
        <Border Grid.Row="2"
                BackgroundColor="LightCoral"
                Stroke="Red"
                StrokeThickness="1"
                Padding="10"
                Margin="15,0,15,10"
                IsVisible="{Binding IsRemovingCourse}">
            
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5"/>
                </Border.StrokeShape>

                <!-- Remove Mode View -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                <Label Grid.Column="0"
                           Text="Select a course to remove"
                           FontAttributes="Bold"
                           TextColor="DarkRed"
                           VerticalOptions="Center"/>
                    
                <Button Grid.Column="1"
                        Text="Cancel"
                        Command="{Binding CancelRemoveCourseCommand}"
                        BackgroundColor="Gray"
                        TextColor="White"/>
            </Grid>
        </Border>
        <!-- End Remove Mode Border -->

        <!-- Add New Course Section -->
        <Border Grid.Row="1" 
                Stroke="DarkBlue"
                StrokeThickness="2"
                Padding="10"
                BackgroundColor="LightBlue"
                Margin="15,0,15,10"
                IsVisible="{Binding IsAddingCourse}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="5"/>
                </Border.StrokeShape>

            <!-- New Course View Row Defitions-->
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                
                <!-- Header -->
                <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                       Text="Add New Course" 
                       FontAttributes="Bold" 
                       FontSize="16" 
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,10"/>

                <!-- New Course Entries -->
                <!-- Course Name -->
                <Label Grid.Row="1" Grid.Column="0" Text="Name:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding NewCourseName}" Placeholder="Enter course name" VerticalOptions="Center"/>
                
                <!-- Course Description -->
                <Label Grid.Row="2" Grid.Column="0" Text="Description:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Editor Grid.Row="2" Grid.Column="1"
                        Text="{Binding NewCourseDescription}"
                        Placeholder="Enter your note here..."
                        HeightRequest="200"
                        AutoSize="TextChanges"
                        />

                <!-- Start Date -->
                <Label Grid.Row="3" Grid.Column="0" Text="Start Date:" FontAttributes="Bold" VerticalOptions="Center"/>
                <DatePicker Grid.Row="3" Grid.Column="1" Date="{Binding NewCourseStartDate}" VerticalOptions="Center"/>

                <!-- End Date -->
                <Label Grid.Row="4" Grid.Column="0" Text="End Date:" FontAttributes="Bold" VerticalOptions="Center"/>
                <DatePicker Grid.Row="4" Grid.Column="1" Date="{Binding NewCourseEndDate}" VerticalOptions="Center"/>

                <!-- Status -->
                <Label Grid.Row="5" Grid.Column="0" Text="Status:" FontAttributes="Bold" VerticalOptions="Center"/>
                <Picker Grid.Row="5" Grid.Column="1" 
                        SelectedItem="{Binding NewCourseStatus}"
                        ItemsSource="{Binding StatusOptions}"
                        VerticalOptions="Center"/>
                <!-- End New Course Entries -->

                <!-- Save/Cancel Button Grid Definitions -->
                <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,10,0,0">

                    <!-- Save Course Button -->
                    <Button Text="Save"
                            Grid.Column="0"
                            Command="{Binding SaveNewCourseCommand}"
                            BackgroundColor="#4CAF50"
                            TextColor="White"/>

                    <!-- Cancel Course Button -->
                    <Button Text="Cancel"
                            Grid.Column="1"
                            Command="{Binding CancelAddCourseCommand}"
                            BackgroundColor="#F44336"
                            TextColor="White"/>
                </Grid>
                <!-- End Save/Cancel Button Grid Section -->
            </Grid>
        </Border>
        <!-- End Add New Course Section -->

        <!-- Course List Section -->
        <RefreshView Grid.Row="3"
                     Command="{Binding LoadCoursesCommand}"  
                     IsRefreshing="{Binding IsRefreshing}">

            <!-- Calls Courses List -->
            <CollectionView ItemsSource="{Binding Courses}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="model:Course">

                        <Grid Padding="10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border StrokeThickness="1"   
                                    Stroke="LightGray"   
                                    Padding="10">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8"/>
                                </Border.StrokeShape>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCourseTapped"/>
                                </Border.GestureRecognizers>

                                <!-- Course Entries -->
                                <VerticalStackLayout Spacing="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- ID -->
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="ID:" FontAttributes="Bold"/>
                                            <Label Text="{Binding Id}"/>

                                        </HorizontalStackLayout>
                                        <!-- Grade -->
                                        <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                            <Label Grid.Column="2"
                                                Text="{Binding Grade}" 
                                                FontAttributes="Bold" 
                                                TextColor="DarkBlue"
                                                HorizontalOptions="End"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                    <!-- Name -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="Name:" FontAttributes="Bold"/>
                                        <Label Text="{Binding Name}" LineBreakMode="TailTruncation"/>
                                    </HorizontalStackLayout>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Dates Column -->
                                        <HorizontalStackLayout Grid.Column="0" Spacing="10">
                                            <Label Text="Dates:" FontAttributes="Bold"/>
                                            <Label>
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding StartDate, StringFormat='{0:MM/dd/yyyy}'}"/>
                                                        <Span Text=" - "/>
                                                        <Span Text="{Binding EndDate, StringFormat='{0:MM/dd/yyyy}'}"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="10">
                                            <!-- Status Column -->
                                            <Label Grid.Column="1"
                                               Text="{Binding Status}" 
                                               FontAttributes="Bold" 
                                               TextColor="DarkBlue"/>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <!-- Empty Course Section -->
                <CollectionView.EmptyView>
                    <StackLayout Padding="20" VerticalOptions="Center">
                        <Label Text="No courses available"   
                               HorizontalOptions="Center"  
                               FontSize="18"  
                               TextColor="Gray"/>
                    </StackLayout>
                </CollectionView.EmptyView>
                <!-- End Empty Course Section -->

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>